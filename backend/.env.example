# Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-pro-latest"

# Limits
MAX_UPLOAD_MB=10
MAX_PAGES=20
MAX_IMAGE_BYTES=4000000

# Timeouts (seconds)
CONVERSION_TIMEOUT_S=45
GEMINI_TIMEOUT_S=60

# Retry/Circuit breaker
GEMINI_RETRY_MAX_ATTEMPTS=3
GEMINI_RETRY_BASE_DELAY_S=1.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_S=60

# Rate limiting (in-memory; future scope: Redis)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
# Use "*" for local dev. For production, set explicit origins.
CORSM_ALLOWED_ORIGINS="*"

